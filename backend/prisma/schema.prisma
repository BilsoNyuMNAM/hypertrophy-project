generator client {
  provider = "prisma-client"
  runtime = "cloudflare"
  output   = "../src/generated/prisma"
}
//  generator clientNode {
//      provider = "prisma-client"
//      runtime   = "nodejs"
//      output    = "../src/generated/prisma-node"
//    }
   
datasource db {
  provider = "postgresql"
}


model Mesocycle{
  id Int @id @default(autoincrement())
  name String @unique
  deletedAt DateTime?
  frequency Frequency[]
  week Week[] 

}

//completed
model Week{
  id Int @id @default(autoincrement())
  week_name String
  mesocycleId Int
  completed Boolean? @default(false)
  deletedAt DateTime?
  mesocycle Mesocycle @relation(fields:[mesocycleId] , references:[id])
  startingvolume StartingVolume[]
  session Session[]
}

model StartingVolume{
  id Int @id @default(autoincrement())
  set Int 
  deletedAt DateTime?
  //2 foreign key will be here 
  //1st foreign key 
  muscleId Int
  muscle Muscle @relation(fields: [muscleId], references: [id])
  //2nd foreign key
  weekId Int
  week Week @relation(fields: [weekId], references: [id])
}

//completed relation between mesocycle and muscle (mesocycle✅, muscle✅)
model Frequency{
  id Int @id @default(autoincrement())
  timesPerWeek Int 
  deletedAt DateTime?
  muscleId Int
  muscle Muscle @relation(fields: [muscleId], references: [id])
  mesocycleId Int
  mesocycle Mesocycle @relation(fields: [mesocycleId], references: [id])
}

//complete the muscle first (starting_volume✅, frequency✅)
model Muscle{
  id Int @id @default(autoincrement())
  muscle_name String @unique
  frequency Frequency[]
  exercise Exercise[]
  startingvolume StartingVolume[]
  sessionmusclefeedback SessionMuscleFeedback[]
}


model Session{
  id Int @id @default(autoincrement())
  session_name String
  deletedAt DateTime?
  weekId Int
  week Week @relation(fields:[weekId], references:[id])
  exerciselogs Exerciselog[] 
  sessionmusclefeedback SessionMuscleFeedback[]
}

// Lookup table - fixed 4 rows, never changes
model Sorenessfeedback{
  id Int @id @default(autoincrement())
  soreness_score Int 
  description String
  sessionmusclefeedback SessionMuscleFeedback[]
}

// Lookup table - fixed 4 rows, never changes
model Performancefeedback{
  id Int @id @default(autoincrement())
  performance_score Int 
  description String
  sessionmusclefeedback SessionMuscleFeedback[]
}

// Junction table - links session + muscle to their selected feedback
model SessionMuscleFeedback{
  id Int @id @default(autoincrement())
  deletedAt DateTime?
  sessionId Int
  session Session @relation(fields:[sessionId], references:[id])
  muscleId Int
  muscle Muscle @relation(fields:[muscleId], references:[id])
  sorenessfeedbackId Int?
  sorenessfeedback Sorenessfeedback? @relation(fields:[sorenessfeedbackId], references:[id])
  performancefeedbackId Int?
  performancefeedback Performancefeedback? @relation(fields:[performancefeedbackId], references:[id])
  
  @@unique([sessionId, muscleId]) // Only one feedback per muscle per session
}

model Exercise{
  id Int @id @default(autoincrement())
  exercise_name String @unique
  exerciselogs Exerciselog[]
  muscleId Int
  muscle Muscle @relation(fields:[muscleId], references:[id])
  
}

model Exerciselog{
  id Int @id @default(autoincrement())
  deletedAt DateTime?
  exerciseId Int
  sessionId Int
  session Session @relation(fields:[sessionId], references: [id])
  exercise Exercise @relation(fields:[exerciseId], references: [id])
  set Set[]
  @@unique([exerciseId, sessionId])
}

model Set{
  id Int @id @default(autoincrement())
  deletedAt DateTime?
  reps Int
  weight Float 
  rir Int
  exerciselogId Int 
  exerciselog Exerciselog @relation(fields:[exerciselogId], references: [id])
}
